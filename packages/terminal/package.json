{
  "name": "@db-mcp/terminal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "db-mcp-tui": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && bun build --target=bun --bundle src/index.ts --outfile dist/tui.js",
    "dev": "bun src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.25.0",
    "@lbelyaev/nexus": "^0.0.1",
    "@mariozechner/pi-tui": "latest",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3",
    "@types/node": "^22"
  }
}
